{
  "planner_type": "robot_arm",

  "results_path": "../results/config6/",
  "map_path": "../maps/map6.json",

  "dimension": 4,
  "bezier_order": 3,
  "continuity_order": 1,
  "h_min": 0.01,
  "h_max": 5.0,

  "path_length_weight": 1.0,
  "path_energy_weight": 0.01,
  "time_weight": 0.01,

  "num_samples": 100,

  "use_convex_relaxation": true,
  "max_rounded_paths": 5,
  "preprocessing": true,

  "robot_arm": {
    "num_joints": 4,

    "link_length": 2.25,
    "link_width": 0.001,
    "link_thickness": 0.001,
    "link_mass": 1.0,

    "obstacle_thickness": 0.5,

    "joint_lower_limits": [0.01, -3.1, -3.1, -3.1],
    "joint_upper_limits": [3.13, 3.1, 3.1, 3.1],

    "q_start": [1.57079632679, 0.0, 0.0, 1.57079632679],
    "q_goal": [2.0, -0.8, -0.6, -0.2],

    "base_position": [5.0, 0.0, 0.0],

    "random_seed": 0,

    "iris": {
      "coverage_termination_threshold": 0.7,
      "iteration_limit": 10,
      "internal_iteration_limit": 1,
      "num_points_per_visibility_round": 500,
      "num_points_per_coverage_check": 800,
      "minimum_clique_size": 3,
      "require_sample_point_is_contained": false
    },

    "collision_checker": {
      "edge_step_size": 0.05,
      "env_collision_padding": 0.0,
      "self_collision_padding": 0.0
    }
  }
